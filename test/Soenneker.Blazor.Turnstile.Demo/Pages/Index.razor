@page "/"
@using Microsoft.Extensions.Logging
@using Soenneker.Blazor.Turnstile.Enums
@using Soenneker.Blazor.Turnstile.Options
@inject ILogger<Index> Logger

<Div Space="Space.Y.Is6">
    <DemoPanel Title="Turnstile" Description="Cloudflare Turnstile widget with test site key.">
        <Turnstile @ref="_turnstile" OnCallback="OnCallback" Options="_options" />
        <DemoButtonRow>
            <Button OnClick="Reset">Reset</Button>
            <Button OnClick="Remove" Variant="ButtonVariant.Secondary">Remove</Button>
            <Button To="/second" Variant="ButtonVariant.Outline">Second page</Button>
        </DemoButtonRow>
    </DemoPanel>
</Div>

@code {
    private Turnstile? _turnstile;

    private readonly TurnstileOptions _options = new()
    {
        SiteKey = "1x00000000000000000000AA",
        Theme = TurnstileTheme.Light
    };

    private void OnCallback(string token)
    {
        Logger.LogInformation("OnCallback fired, token: {token}", token);
    }

    private async Task Reset()
    {
        await _turnstile!.Reset();
    }

    private async Task Remove()
    {
        await _turnstile!.Remove();
    }
}
